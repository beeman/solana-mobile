{
  "bin": {
    "solana-mobile": "dist/cli.mjs"
  },
  "bugs": {
    "url": "https://github.com/beeman/solana-mobile/issues"
  },
  "dependencies": {
    "@clack/prompts": "1.6.0",
    "commander": "14.0.3"
  },
  "description": "CLI for Solana Mobile development.",
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@changesets/cli": "2.30.0",
    "@intellectronica/ruler": "0.3.38",
    "@types/bun": "1.3.13",
    "lefthook": "2.1.5",
    "pkg-pr-new": "0.0.62",
    "publint": "0.3.18",
    "tsdown": "0.21.7",
    "typescript": "6.0.2"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/beeman/solana-mobile#readme",
  "license": "MIT",
  "name": "solana-mobile",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeman/solana-mobile.git"
  },
  "scripts": {
    "build": "tsdown",
    "changeset": "changeset",
    "check-types": "tsc -b --noEmit",
    "ci": "bun run build && bun run lint && bun run check-types && bun run test",
    "dev": "bun run src/cli.ts",
    "lint": "biome check --error-on-warnings",
    "lint:fix": "biome check --error-on-warnings --write",
    "prepare": "lefthook install",
    "release": "changeset publish",
    "ruler:apply": "ruler apply --local-only",
    "test": "bun test test/*.test.ts",
    "test:watch": "bun test test/*.test.ts --watch",
    "version": "changeset version && bun lint:fix"
  },
  "type": "module",
  "version": "0.0.0"
}
